// Studelio — schéma Prisma (spécification produit)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  PARENT
  CORRECTOR
  ADMIN
}

enum Niveau {
  SIXIEME
  CINQUIEME
  QUATRIEME
  TROISIEME
  SECONDE
  PREMIERE
  TERMINALE
  BTS
}

enum Tag {
  DYSLEXIE
  DYSORTHOGRAPHIE
  DYSCALCULIE
  TDAH
  HPI
  TROUBLE_ANXIEUX
}

enum Plan {
  ESSENTIEL
  STANDARD
  INTENSIF
}

enum SubStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum MessageRole {
  USER
  ANDRE
}

enum ChatSessionKind {
  FREE
  PROGRAMME_GUIDED
  DICTATION
}

enum BacBlancStatus {
  PENDING
  SUBMITTED
  IN_REVIEW
  CORRECTED
}

/// Brevet blanc (collège) vs bac blanc (lycée / BTS).
enum BlancKind {
  BREVET_BLANC
  BAC_BLANC
}

enum ChapterProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum OrderKind {
  SUBSCRIPTION
  BLANC_ADDON
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELED
  REFUNDED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  role          Role      @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscription       Subscription?
  studentProfile     StudentProfile?
  parentProfile      ParentProfile?
  chatSessions       ChatSession[]
  bacBlancs          BacBlanc[]       @relation("BacBlancStudent")
  correctedBacBlancs     BacBlanc[]          @relation("BacBlancCorrecteur")
  blancEnrollments       BlancEnrollment[]   @relation("BlancEnrollmentStudent")
  correctedBlancEnrollments BlancEnrollment[] @relation("BlancEnrollmentCorrecteur")
  blancOneTimePurchases  BlancOneTimePurchase[]
  orders                 Order[]
  accounts               Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model StudentProfile {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  niveau                 Niveau
  interests              String[]
  tags                   Tag[]
  parentId               String?
  parent                 ParentProfile? @relation(fields: [parentId], references: [id])
  streakDays             Int       @default(0)
  totalMinutes           Int       @default(0)
  lastSessionAt          DateTime?
  errorProfile           Json      @default("{}")
  programmeId            String?
  programme              Programme? @relation(fields: [programmeId], references: [id])
  onboardingCompletedAt  DateTime?
  chapterProgress        StudentChapterProgress[]
  competencyProgress     StudentCompetencyProgress?
}

/// Scores 0–100 par axe, mis à jour depuis les séances « programme guidé » (bloc META en fin de message André).
model StudentCompetencyProgress {
  id                 String         @id @default(cuid())
  studentProfileId   String         @unique
  studentProfile     StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  grammaire          Int            @default(0)
  orthographe        Int            @default(0)
  conjugaison        Int            @default(0)
  vocabulaire        Int            @default(0)
  expressionEcrite   Int            @default(0)
  lecture            Int            @default(0)
  updatedAt          DateTime       @updatedAt
}

model ParentProfile {
  id               String           @id @default(cuid())
  userId           String           @unique
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  children         StudentProfile[]
  emailReports     Boolean          @default(true)
  reportFrequency  String           @default("weekly")
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId     String    @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  plan                 Plan      @default(ESSENTIEL)
  status               SubStatus @default(INCOMPLETE)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

/// Commande enregistrée depuis Stripe Checkout (abonnement ou bac blanc à l’unité).
model Order {
  id                        String      @id @default(cuid())
  stripeCheckoutSessionId   String      @unique
  userId                    String
  user                      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind                      OrderKind
  status                    OrderStatus @default(PENDING)
  currency                  String      @default("eur")
  totalAmountCents          Int
  stripePaymentIntentId     String?
  stripeSubscriptionId      String?
  customerEmail             String?
  createdAt                 DateTime    @default(now())
  updatedAt                 DateTime    @updatedAt

  lines OrderLine[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model OrderLine {
  id               String @id @default(cuid())
  orderId          String
  order            Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  label            String
  quantity         Int    @default(1)
  unitAmountCents  Int
  stripePriceId    String?
}

model ChatSession {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     String?
  niveau      Niveau?
  kind        ChatSessionKind  @default(FREE)
  dictationId String?
  dictation   ProgrammeDictation? @relation(fields: [dictationId], references: [id], onDelete: SetNull)
  messages    ChatMessage[]
  attachments Attachment[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([dictationId])
}

model ChatMessage {
  id         String      @id @default(cuid())
  sessionId  String
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role       MessageRole
  content    String      @db.Text
  tokensUsed Int?
  createdAt  DateTime    @default(now())
}

model Attachment {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  url       String
  type      String
  filename  String
  sizeBytes Int
  createdAt DateTime    @default(now())
}

model Programme {
  id          String              @id @default(cuid())
  niveau      Niveau              @unique
  title       String
  description String?
  /// Consignes pédagogiques pour l’IA (souvent importées depuis content/programmes/{NIVEAU}.md au seed).
  aiBrief     String?             @db.Text
  chapters    ProgrammeChapter[]
  dictations  ProgrammeDictation[]
  students    StudentProfile[]
  updatedAt   DateTime            @updatedAt
}

/// Dictée : audio + texte corrigé (géré dans le backoffice). Le corrigé n’est pas injecté dans le prompt LLM.
model ProgrammeDictation {
  id            String    @id @default(cuid())
  programmeId   String
  programme     Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  title         String
  /// URL publique (mp3, m4a, mp4, etc.) — ex. Uploadthing ou hébergeur externe.
  audioUrl      String
  correctedText String    @db.Text
  order         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  chatSessions  ChatSession[]

  @@index([programmeId, order])
}

model ProgrammeChapter {
  id              String                   @id @default(cuid())
  programmeId     String
  programme       Programme                @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  order           Int
  objectives      String[]
  skills          String[]
  systemPrompt    String?                  @db.Text
  studentProgress StudentChapterProgress[]
}

model StudentChapterProgress {
  id               String                @id @default(cuid())
  studentProfileId String
  studentProfile   StudentProfile        @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  chapterId        String
  chapter          ProgrammeChapter      @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  status           ChapterProgressStatus @default(NOT_STARTED)
  /// Incrémenté à chaque META séance programme qui cite ce module (passage auto en cours / terminé).
  programmeMetaHits Int                  @default(0)
  updatedAt        DateTime              @updatedAt

  @@unique([studentProfileId, chapterId])
}

model BacBlanc {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation("BacBlancStudent", fields: [userId], references: [id], onDelete: Cascade)
  sessionNumber    Int
  trimestre        Int
  niveau           Niveau
  subject          String
  sujetUrl         String?
  copieUrl         String?
  /// Date et heure de la séance en visioconférence.
  visioAt          DateTime?
  /// Lien Zoom, Meet, Teams, etc.
  visioUrl         String?
  /// Libellé court affiché à l’élève (ex. « Salle A »).
  visioLabel       String?
  status           BacBlancStatus @default(PENDING)
  correcteurId     String?
  correcteur       User?          @relation("BacBlancCorrecteur", fields: [correcteurId], references: [id])
  noteFinale       Float?
  noteDetails      Json?
  commentaire      String?        @db.Text
  copieCorrigeeUrl String?
  submittedAt      DateTime?
  correctedAt      DateTime?
  createdAt        DateTime       @default(now())

  @@unique([userId, trimestre, sessionNumber])
}

/// Créneau proposé par l’admin (inscription libre des élèves du bon niveau).
model BlancSlot {
  id          String    @id @default(cuid())
  title       String
  kind        BlancKind
  description String?   @db.Text
  visioAt     DateTime?
  visioUrl    String?
  visioLabel  String?
  /// Lien du sujet (PDF, page…) — visible aux élèves inscrits.
  sujetUrl    String?
  published   Boolean   @default(false)
  /// Nombre max d’inscrits ; null = illimité.
  capacity    Int?
  /// Après cette date, plus d’inscription (null = pas de limite).
  closesAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  enrollments BlancEnrollment[]
}

model BlancEnrollment {
  id           String          @id @default(cuid())
  slotId       String
  slot         BlancSlot       @relation(fields: [slotId], references: [id], onDelete: Cascade)
  userId       String
  user         User            @relation("BlancEnrollmentStudent", fields: [userId], references: [id], onDelete: Cascade)
  status       BacBlancStatus  @default(PENDING)
  copieUrl     String?
  noteFinale   Float?
  commentaire  String?         @db.Text
  correcteurId String?
  correcteur   User?           @relation("BlancEnrollmentCorrecteur", fields: [correcteurId], references: [id])
  submittedAt  DateTime?
  correctedAt  DateTime?
  createdAt    DateTime        @default(now())
  /// Inscription payée à l’unité (offres Essentiel / Progression).
  blancPurchaseId String?       @unique
  blancPurchase   BlancOneTimePurchase? @relation(fields: [blancPurchaseId], references: [id], onDelete: SetNull)
  /// Acheté avec l’option « + correction enseignant » (20 €).
  proCorrectionPurchased Boolean @default(false)

  @@unique([slotId, userId])
}

/// Achat ponctuel d’une place examen blanc / brevet blanc (hors offre Excellence).
model BlancOneTimePurchase {
  id                       String    @id @default(cuid())
  userId                   String
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  includesProCorrection    Boolean   @default(false)
  stripeCheckoutSessionId  String    @unique
  amountTotalCents         Int
  /// Rempli quand une inscription a consommé ce crédit ; remis à null si l’élève annule une inscription encore « PENDING ».
  consumedAt               DateTime?
  createdAt                DateTime  @default(now())

  enrollment BlancEnrollment?

  @@index([userId, consumedAt])
}

model ApiConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
  updatedBy String
}
