# Base
# Avec Docker : copie cette ligne dans .env puis `docker compose up -d` et `npx prisma migrate dev`
DATABASE_URL="postgresql://studelio:studelio@localhost:5432/studelio"
AUTH_SECRET=""
NEXTAUTH_SECRET=""
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# OAuth (optionnel au démarrage)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# --- Stripe (test : clés sk_test_ / pk_test_ ; prod : sk_live_ / pk_live_) ---
# 1) Dashboard → Developers → API keys : STRIPE_SECRET_KEY = Secret key ; NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY = Publishable (optionnel si tu n’utilises que Checkout hébergé).
# 2) Products : 3 prix récurrents mensuels (Essentiel 9,99 €, Progression 15,99 €, Excellence 25,99 €) → STRIPE_PRICE_* = Price ID (price_…).
# 3) Settings → Customer portal : activer le portail + produits autorisés (sinon le bouton Paramètres échouera).
# 4) Developers → Webhooks → Add endpoint : {AUTH_URL}/api/stripe/webhook
#    Événements : checkout.session.completed, customer.subscription.updated, customer.subscription.deleted, invoice.payment_failed
# 5) Copier le « Signing secret » du endpoint → STRIPE_WEBHOOK_SECRET (whsec_…).
# 6) Local : `stripe listen --forward-to localhost:3000/api/stripe/webhook` puis coller le whsec affiché dans .env
# 7) AUTH_URL / NEXTAUTH_URL = URL publique exacte (ex. https://tondomaine.com) — même base que l’URL du webhook.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_ESSENTIEL=""
STRIPE_PRICE_STANDARD=""
STRIPE_PRICE_INTENSIF=""
# Checkout abonnement : essai 3 jours (trial_period_days). Paiements bac blanc : montants en dur (15 € / 20 €) dans le code.

# Anthropic (André)
ANTHROPIC_API_KEY=""
# Optionnel — défaut dans le code : claude-sonnet-4-6
ANTHROPIC_MODEL=""

# Uploadthing (dictées audio admin — optionnel si tu colles une URL externe)
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""
# Même valeur que l’App ID dashboard Uploadthing (exposée au navigateur pour le bouton d’upload)
NEXT_PUBLIC_UPLOADTHING_APP_ID=""

# Resend (emails transactionnels / rétention — à brancher selon les besoins)
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# Chiffrement clés API admin
ENCRYPTION_KEY=""

# Rate limiting
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
