# Base
# Avec Docker : copie cette ligne dans .env puis `docker compose up -d` et `npx prisma migrate dev`
DATABASE_URL="postgresql://studelio:studelio@localhost:5432/studelio"
AUTH_SECRET=""
NEXTAUTH_SECRET=""
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# OAuth (optionnel au démarrage)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# Stripe (Price IDs = recurring prices dans le Dashboard Stripe, un par plan)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_ESSENTIEL=""
STRIPE_PRICE_STANDARD=""
STRIPE_PRICE_INTENSIF=""
# Webhook endpoint à enregistrer dans Stripe : {AUTH_URL}/api/stripe/webhook — événements : checkout.session.completed, customer.subscription.updated, customer.subscription.deleted

# Anthropic (André)
ANTHROPIC_API_KEY=""
# Optionnel — défaut dans le code : claude-sonnet-4-6
ANTHROPIC_MODEL=""

# Uploadthing (dictées audio admin — optionnel si tu colles une URL externe)
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""
# Même valeur que l’App ID dashboard Uploadthing (exposée au navigateur pour le bouton d’upload)
NEXT_PUBLIC_UPLOADTHING_APP_ID=""

# Resend (emails transactionnels / rétention — à brancher selon les besoins)
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# Chiffrement clés API admin
ENCRYPTION_KEY=""

# Rate limiting
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
